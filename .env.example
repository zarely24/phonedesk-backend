# Copy to .env for local dev, or set these in Render's Environment tab for production.

# Local dev uses SQLite (no setup). On Render, this is provided automatically by the Postgres add-on.
DATABASE_URL=sqlite:///./phonedesk.db

# CHANGE THESE to long random strings in production.
JWT_SECRET=change-me-to-a-long-random-string
DEVICE_TOKEN_PEPPER=change-me-too-to-something-random

# Bootstrap admin (created on first run). Change the password!
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=admin1234
